// Example: Fibonacci Sequence
// Version: 0.1.0
// License: MPL 2.0

fibonacci(n) {
    if n <= 1 {
        return n
    }
    return fibonacci(n - 1) + fibonacci(n - 2)
}

main() {
    i = 0

    while i < 10 {
        fib = fibonacci(i)
        // print(fib)
        i = i + 1
    }
}
