// Halo Language - Performance Benchmark
// Recursive Fibonacci + intensive loop
// Used to measure interpreter and compiler performance.

fib(n) {
    if n <= 1 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

sum_loop(n) {
    i = 0
    acc = 0
    while i < n {
        acc = acc + i
        i = i + 1
    }
    return acc
}

// --- Fibonacci ---
print(fib(30))

// --- Loop sum: 0+1+...+999999 ---
print(sum_loop(999999))
